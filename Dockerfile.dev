FROM node:20-alpine

WORKDIR /app

# pnpm のインストール（バージョン固定）
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# pnpm ストアパスをプロジェクト内に固定（ボリュームマウント後も一致させる）
RUN pnpm config set store-dir /app/.pnpm-store

# 依存パッケージのインストール（キャッシュ活用）
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install

# ソースコードはボリュームマウントで提供するため COPY 不要（dev 専用）

EXPOSE 3000

CMD ["pnpm", "dev"]
